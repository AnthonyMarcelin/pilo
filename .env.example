APP_NAME=Pilo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# URL publique exacte (utilisée pour générer les liens, assets, cookies)
APP_URL=https://pilo.example.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Base de données SQLite ──────────────────────────────────────────────────
# Fichier persisté dans le volume Docker sqlite_data (monté sur /var/sqlite).
DB_CONNECTION=sqlite
DB_DATABASE=/var/sqlite/database.sqlite

# ── Cache, sessions, queues ─────────────────────────────────────────────────
# CACHE_STORE (et non CACHE_DRIVER — renommé en Laravel 11)
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

# ── Reverse proxy (Traefik, Nginx, Caddy…) ─────────────────────────────────
# Requis pour que Laravel génère des liens https derrière un proxy TLS.
# Valeurs : '*' (tous les proxies) | IP/CIDR | séparés par virgule.
# Laisser vide en dev direct (sans proxy).
TRUSTED_PROXIES=*

# ── IA locale (PaddleOCR-VL + Ollama) ──────────────────────────────────────
# Démarrée à la demande uniquement (profil Docker "ai"), jamais au repos.
# Le worker de scan exécute pilo:ai-up / pilo:ai-down automatiquement.
OCR_PROVIDER=local
PADDLEOCR_URL=http://paddleocr-vl:8000
OLLAMA_URL=http://ollama:11434
# Modèle retenu : 3b-instruct (le 1.5B hallucine sur entrée vide — critère de sécurité)
OLLAMA_MODEL=qwen2.5:3b-instruct

# ── Alertes et comportement IA ──────────────────────────────────────────────
ALERT_THRESHOLD_DAYS=7
AI_IDLE_SECONDS=300

# ── Compte propriétaire ─────────────────────────────────────────────────────
# Utilisé par OwnerSeeder pour créer le premier compte.
# À changer IMPÉRATIVEMENT avant le premier démarrage.
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=changeme123
