APP_NAME=Pilo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=pilo
DB_USERNAME=pilo
DB_PASSWORD=changeme

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

# IA locale (PaddleOCR + Ollama) — démarrée à la demande, voir CLAUDE.md §3.1
OCR_PROVIDER=local
PADDLEOCR_URL=http://paddleocr:8000
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# Alertes stock et délai auto-stop IA
ALERT_THRESHOLD_DAYS=7
AI_IDLE_TIMEOUT_SECONDS=300

# Compte propriétaire (initialisation — changer au premier login)
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=changeme123
