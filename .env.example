APP_NAME=Pilo
# En production : changer en votre URL publique (ex. https://pilo.example.com)
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de données SQLite — fichier persisté dans le volume Docker sqlite_data
# Chemin absolu dans le conteneur (volume monté sur /var/sqlite).
DB_CONNECTION=sqlite
DB_DATABASE=/var/sqlite/database.sqlite

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

# ── IA locale (PaddleOCR-VL + Ollama) ──────────────────────────────────────
# Démarrée à la demande uniquement (profil Docker "ai"), jamais au repos.
# Le worker de scan exécute pilo:ai-up / pilo:ai-down automatiquement.
OCR_PROVIDER=local
PADDLEOCR_URL=http://paddleocr-vl:8000
OLLAMA_URL=http://ollama:11434
# Modèle retenu : 3b-instruct (le 1.5B hallucine sur entrée vide — critère de sécurité)
OLLAMA_MODEL=qwen2.5:3b-instruct

# ── Alertes et comportement IA ──────────────────────────────────────────────
# Nombre de jours avant fin de stock déclenchant l'alerte renouvellement
ALERT_THRESHOLD_DAYS=7
# Délai d'inactivité (secondes) après le dernier scan avant d'éteindre les services IA
AI_IDLE_SECONDS=300

# ── Compte propriétaire ─────────────────────────────────────────────────────
# Utilisé par le seeder pour créer le premier compte. Changer avant le premier démarrage.
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=changeme123
