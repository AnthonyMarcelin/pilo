APP_NAME=Pilo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de données SQLite — fichier persisté dans le volume Docker sqlite_data
# Chemin absolu dans le conteneur (volume monté sur /var/sqlite).
DB_CONNECTION=sqlite
DB_DATABASE=/var/sqlite/database.sqlite

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

# IA locale (PaddleOCR + Ollama) — démarrée à la demande, voir CLAUDE.md §3.1
OCR_PROVIDER=local
PADDLEOCR_URL=http://paddleocr:8000
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# Alertes stock et délai auto-stop IA
ALERT_THRESHOLD_DAYS=7
AI_IDLE_TIMEOUT_SECONDS=300

# Compte propriétaire (initialisation — changer au premier login)
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=changeme123
